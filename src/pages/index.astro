---
// Dziwne Wody — Easter Egg Quiz
// Static single-page quiz. No SSR needed.
---

<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Doto:wght@400;700;900&display=swap"
      rel="stylesheet"
    />
    <title>Czy znasz Dziwne Wody? | Quiz</title>
    <meta
      name="description"
      content="Sprawdź swoją wiedzę o Dziwnych Wodach i zgarnij nagrodę."
    />
    <meta property="og:title" content="Czy znasz Dziwne Wody? | Quiz" />
    <meta
      property="og:description"
      content="Sprawdź swoją wiedzę o Dziwnych Wodach i zgarnij nagrodę."
    />
    <meta property="og:type" content="website" />
  </head>

  <body>
    <header>
      <a
        href="https://dziwnewody.xyz"
        target="_blank"
        rel="noopener"
        class="logo"
      >
        <img src="/logo.png" alt="Dziwne Wody" class="logo-img" />
      </a>
    </header>

    <main>
      <!-- QUIZ -->
      <div id="quiz" class="screen active">
        <div class="progress-bar">
          <div class="progress-fill" id="progress-fill"></div>
        </div>
        <div class="step-counter" id="step-counter">01/04</div>
        <div class="quiz-inner" id="quiz-inner">
          <h1 class="question" id="question-text"></h1>
          <div class="answers" id="answers-container"></div>
        </div>
        <button class="btn-primary" id="btn-next" disabled>DALEJ</button>
      </div>

      <!-- SUCCESS -->
      <div id="success" class="screen">
        <div class="result-content">
          <h1>GRATULACJE!</h1>
          <p class="result-desc">
            No no no, ktoś tu ogarnia temat! Widzę, że masz
            nosa — dosłownie i w przenośni. Łap kod
            rabatowy, zasłużyłeś/aś.
          </p>
          <div class="dog-image-wrap">
            <img src="/dog.png" alt="Pies Dziwnych Wód" class="dog-image" />
          </div>
          <div class="code-box">
            <span class="code-label">TWÓJ KOD RABATOWY</span>
            <div class="code-display">
              <span id="discount-code"></span>
              <button class="btn-copy" id="btn-copy">KOPIUJ</button>
            </div>
            <span class="code-info">-15% na następne zamówienie</span>
          </div>
          <a
            href="https://dziwnewody.xyz"
            target="_blank"
            rel="noopener"
            class="btn-primary btn-shop"
          >
            WRÓĆ DO SKLEPU →
          </a>
        </div>
      </div>

      <!-- FAILURE -->
      <div id="failure" class="screen">
        <div class="result-content">
          <h1>NIE TYM RAZEM...</h1>
          <p class="result-desc">
            Coś nie pykło... ale spokojnie, wystarczy trochę
            więcej obcowania z Dziwnymi Wodami. Może wpadnij do nas na
            Kościuszki 69 i dowiedz się więcej na żywo?
          </p>
          <button class="btn-primary btn-retry" id="btn-retry">
            SPRÓBUJ PONOWNIE
          </button>
        </div>
      </div>
    </main>

    <footer>
      <span>&copy; Dziwne Wody</span>
    </footer>
  </body>
</html>

<style is:global>
  /* ========================================
     RESET & BASE
     ======================================== */
  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    font-family: "Doto", "Courier New", Courier, monospace;
    font-weight: 700;
    color: #fff;
    background: #000;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  /* ========================================
     HEADER
     ======================================== */
  header {
    padding: 1.25rem 1.5rem;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 10;
    display: flex;
    justify-content: center;
  }

  .logo {
    display: block;
    opacity: 0.7;
    transition: opacity 0.15s ease;
  }
  .logo:hover {
    opacity: 1;
  }
  .logo-img {
    height: 28px;
    width: auto;
    display: block;
  }

  /* ========================================
     FOOTER
     ======================================== */
  footer {
    padding: 1.25rem 1.5rem;
    text-align: center;
    font-size: 0.65rem;
    color: #333;
    letter-spacing: 0.08em;
  }

  /* ========================================
     MAIN
     ======================================== */
  main {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 5rem 1.5rem 2rem;
  }

  /* ========================================
     SCREENS
     ======================================== */
  .screen {
    display: none;
    width: 100%;
    max-width: 640px;
  }
  .screen.active {
    display: block;
    animation: screenIn 0.25s ease-out;
  }

  @keyframes screenIn {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ========================================
     PROGRESS BAR
     ======================================== */
  .progress-bar {
    width: 100%;
    height: 2px;
    background: #1a1a1a;
    margin-bottom: 1.25rem;
  }
  .progress-fill {
    height: 100%;
    background: #00d456;
    width: 25%;
    transition: width 0.35s cubic-bezier(0.33, 1, 0.68, 1);
  }

  .step-counter {
    font-size: 0.75rem;
    color: #555;
    margin-bottom: 2rem;
    letter-spacing: 0.15em;
  }

  /* ========================================
     QUIZ INNER (animated on step change)
     ======================================== */
  .quiz-inner {
    animation: questionIn 0.2s ease-out;
  }
  .quiz-inner.transitioning {
    animation: questionOut 0.15s ease-in forwards;
  }

  @keyframes questionIn {
    from {
      opacity: 0;
      transform: translateX(20px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
  @keyframes questionOut {
    from {
      opacity: 1;
      transform: translateX(0);
    }
    to {
      opacity: 0;
      transform: translateX(-20px);
    }
  }

  /* ========================================
     QUESTION
     ======================================== */
  .question {
    font-size: clamp(1.2rem, 3.5vw, 1.75rem);
    line-height: 1.25;
    margin-bottom: 2rem;
    letter-spacing: -0.02em;
  }

  /* ========================================
     ANSWERS
     ======================================== */
  .answers {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    margin-bottom: 2.5rem;
  }

  .answer-btn {
    width: 100%;
    background: transparent;
    border: 1px solid #fff;
    color: #fff;
    font-family: "Doto", "Courier New", Courier, monospace;
    font-weight: 700;
    font-size: 0.875rem;
    padding: 1.125rem 1.25rem;
    min-height: 3.5rem;
    text-align: left;
    cursor: pointer;
    line-height: 1.45;
    letter-spacing: -0.01em;
    display: flex;
    align-items: center;
    transition:
      border-color 0.12s ease,
      color 0.12s ease,
      background 0.12s ease;
  }
  .answer-btn:hover {
    border-color: #00d456;
    color: #fff;
  }
  .answer-btn.selected {
    border-color: #00d456;
    color: #000;
    background: #00d456;
  }

  /* ========================================
     BUTTONS
     ======================================== */
  .btn-primary {
    display: block;
    width: 100%;
    background: #00d456;
    color: #000;
    border: none;
    font-family: "Doto", "Courier New", Courier, monospace;
    font-weight: 900;
    font-size: 0.9rem;
    padding: 1rem 2rem;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-decoration: none;
    text-align: center;
    transition:
      background 0.15s ease,
      opacity 0.15s ease;
  }
  .btn-primary:hover {
    background: #00c04e;
  }
  .btn-primary:disabled {
    opacity: 0.2;
    cursor: not-allowed;
    background: #00d456;
  }

  /* ========================================
     RESULT SCREENS
     ======================================== */
  .result-content {
    text-align: center;
  }
  .result-content h1 {
    font-size: clamp(1.75rem, 6vw, 3rem);
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
    line-height: 1;
  }
  .result-desc {
    font-size: 0.9rem;
    color: #999;
    line-height: 1.65;
    margin-bottom: 2.5rem;
    max-width: 440px;
    margin-inline: auto;
    font-weight: 400;
  }

  /* ========================================
     DOG IMAGE
     ======================================== */
  .dog-image-wrap {
    width: 260px;
    height: 260px;
    margin: 0 auto 2.5rem;
    border: 1px solid #2a2a2a;
    overflow: hidden;
  }
  .dog-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ========================================
     DISCOUNT CODE BOX
     ======================================== */
  .code-box {
    border: 1px solid #00d456;
    padding: 1.75rem 1.5rem;
    margin-bottom: 2rem;
  }
  .code-label {
    font-size: 0.65rem;
    color: #555;
    letter-spacing: 0.15em;
    display: block;
    margin-bottom: 0.875rem;
  }
  .code-display {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.875rem;
    margin-bottom: 0.875rem;
    flex-wrap: wrap;
  }
  .code-display span {
    font-size: clamp(1.25rem, 4.5vw, 2rem);
    color: #00d456;
    letter-spacing: 0.06em;
  }
  .btn-copy {
    background: transparent;
    border: 1px solid #00d456;
    color: #00d456;
    font-family: "Doto", "Courier New", Courier, monospace;
    font-weight: 700;
    font-size: 0.6rem;
    padding: 0.4rem 0.75rem;
    cursor: pointer;
    letter-spacing: 0.08em;
    transition:
      background 0.12s ease,
      color 0.12s ease;
  }
  .btn-copy:hover {
    background: rgba(0, 212, 86, 0.12);
  }
  .btn-copy.copied {
    background: #00d456;
    color: #000;
  }
  .code-info {
    font-size: 0.8rem;
    color: #777;
    font-weight: 400;
  }

  .btn-shop {
    max-width: 320px;
    margin: 0 auto;
  }

  /* ========================================
     FAILURE
     ======================================== */
  #failure .result-content h1 {
    color: #d43a3c;
  }
  .btn-retry {
    max-width: 320px;
    margin: 0 auto;
  }

  /* ========================================
     RESPONSIVE
     ======================================== */
  @media (max-width: 640px) {
    main {
      align-items: flex-start;
      padding: 4.25rem 1.25rem 1.5rem;
    }

    .question {
      font-size: 1.15rem;
      margin-bottom: 1.5rem;
    }

    .answers {
      gap: 0.5rem;
      margin-bottom: 2rem;
    }

    .answer-btn {
      font-size: 0.8rem;
      padding: 0.875rem 1rem;
      min-height: 3rem;
    }

    .result-content h1 {
      font-size: 1.75rem;
    }

    .result-desc {
      font-size: 0.85rem;
    }

    .dog-image-wrap {
      width: 200px;
      height: 200px;
    }

    .code-box {
      padding: 1.25rem 1rem;
    }

    .code-display span {
      font-size: 1.2rem;
    }

    .btn-shop,
    .btn-retry {
      max-width: 100%;
    }
  }

  @media (max-width: 360px) {
    main {
      padding: 3.75rem 1rem 1rem;
    }

    .answer-btn {
      font-size: 0.75rem;
      padding: 0.75rem 0.875rem;
    }

    .dog-image-wrap {
      width: 180px;
      height: 180px;
    }
  }
</style>

<script>
  // =============================================
  // QUIZ DATA
  // =============================================
  const quizData = [
    {
      q: "Gdzie zlokalizowane s\u0105 Dziwne Wody?",
      a: [
        "Taczaka 20, Pozna\u0144",
        "Ko\u015Bciuszki 69, Pozna\u0144",
        "Owsiana 13, Pozna\u0144",
        "Suchodolskiego 26, Pozna\u0144",
      ],
      c: 1,
    },
    {
      q: "Ile zapach\u00F3w z serii Pollution ujrza\u0142o \u015Bwiat\u0142o dzienne?",
      a: ["4", "6", "7", "9"],
      c: 2,
    },
    {
      q: "Sk\u0105d pochodzi marka HUNQ?",
      a: [
        "Tirana, Albania",
        "Warszawa, Polska",
        "Berlin, Niemcy",
        "Amsterdam, Holandia",
      ],
      c: 3,
    },
    {
      q: "Jak pachnie organiczny zwi\u0105zek chemiczny SKATOL?",
      a: [
        "Skatol jest cz\u0119\u015Bci\u0105 zapachu r\u00F3\u017Cy.",
        "Skatol pachnie \u015Bwie\u017Co \u015Bci\u0119t\u0105 traw\u0105.",
        "G\u00D3WNEM!",
        "Skatol odpowiada za pudrowe frakcje fio\u0142ka.",
      ],
      c: 2,
    },
  ];

  // Obfuscated discount code (char codes offset by key)
  const _k = 7;
  const _d = [56, 55, 55, 55, 80, 88, 60, 79, 76, 72, 75];

  // =============================================
  // SHUFFLE
  // =============================================
  function shuffle(
    answers: string[],
    correctIdx: number
  ): { shuffled: string[]; newCorrectIdx: number } {
    const indexed = answers.map((text, i) => ({
      text,
      isCorrect: i === correctIdx,
    }));
    for (let i = indexed.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [indexed[i]!, indexed[j]!] = [indexed[j]!, indexed[i]!];
    }
    return {
      shuffled: indexed.map((x) => x.text),
      newCorrectIdx: indexed.findIndex((x) => x.isCorrect),
    };
  }

  function buildShuffled() {
    return quizData.map((q) => {
      const { shuffled, newCorrectIdx } = shuffle(q.a, q.c);
      return { question: q.q, answers: shuffled, correctIdx: newCorrectIdx };
    });
  }

  // =============================================
  // STATE
  // =============================================
  let data = buildShuffled();
  let step = 0;
  let selected: number[] = [-1, -1, -1, -1];

  // =============================================
  // DOM
  // =============================================
  const $quiz = document.getElementById("quiz")!;
  const $success = document.getElementById("success")!;
  const $failure = document.getElementById("failure")!;
  const $progress = document.getElementById("progress-fill")!;
  const $step = document.getElementById("step-counter")!;
  const $inner = document.getElementById("quiz-inner")!;
  const $question = document.getElementById("question-text")!;
  const $answers = document.getElementById("answers-container")!;
  const $next = document.getElementById("btn-next") as HTMLButtonElement;
  const $code = document.getElementById("discount-code")!;
  const $copy = document.getElementById("btn-copy")!;
  const $retry = document.getElementById("btn-retry")!;

  // =============================================
  // RENDER
  // =============================================
  function render() {
    const q = data[step]!;
    const total = data.length;

    // Progress
    $progress.style.width = `${((step + 1) / total) * 100}%`;
    $step.textContent = `${String(step + 1).padStart(2, "0")}/${String(total).padStart(2, "0")}`;

    // Question
    $question.textContent = q.question;

    // Answers
    $answers.innerHTML = "";
    q.answers.forEach((text, i) => {
      const btn = document.createElement("button");
      btn.className = "answer-btn";
      if (selected[step] === i) btn.classList.add("selected");
      btn.textContent = text;
      btn.addEventListener("click", () => pick(i));
      $answers.appendChild(btn);
    });

    // Button label
    $next.textContent = step === total - 1 ? "SPRAWDŹ" : "DALEJ";
    $next.disabled = selected[step] === -1;

    // Re-trigger inner animation
    $inner.style.animation = "none";
    $inner.offsetHeight; // force reflow
    $inner.style.animation = "";
  }

  function pick(i: number) {
    selected[step] = i;
    document.querySelectorAll(".answer-btn").forEach((btn, idx) => {
      btn.classList.toggle("selected", idx === i);
    });
    $next.disabled = false;
  }

  function showScreen(id: string) {
    [$quiz, $success, $failure].forEach((s) => s.classList.remove("active"));
    document.getElementById(id)!.classList.add("active");
  }

  function evaluate() {
    const allCorrect = data.every((q, i) => selected[i] === q.correctIdx);
    if (allCorrect) {
      // Decode discount code
      $code.textContent = _d.map((c) => String.fromCharCode(c - _k)).join("");
      showScreen("success");
    } else {
      showScreen("failure");
    }
  }

  function reset() {
    step = 0;
    selected = [-1, -1, -1, -1];
    data = buildShuffled();
    showScreen("quiz");
    render();
  }

  // =============================================
  // EVENTS
  // =============================================
  $next.addEventListener("click", () => {
    if (step < data.length - 1) {
      // Transition out, then advance
      $inner.classList.add("transitioning");
      setTimeout(() => {
        step++;
        $inner.classList.remove("transitioning");
        render();
      }, 150);
    } else {
      evaluate();
    }
  });

  $copy.addEventListener("click", () => {
    const code = $code.textContent || "";
    navigator.clipboard.writeText(code).then(() => {
      $copy.textContent = "SKOPIOWANO!";
      $copy.classList.add("copied");
      setTimeout(() => {
        $copy.textContent = "KOPIUJ";
        $copy.classList.remove("copied");
      }, 2000);
    });
  });

  $retry.addEventListener("click", reset);

  // =============================================
  // INIT
  // =============================================
  render();
</script>
